# Copy to .env and fill in values. See src/lib/env.ts for validation rules.
# Legend: [required] must be set • [required in prod] must be set when NODE_ENV=production • [optional]

# ── Runtime ─────────────────────────────────────────────────────────────
# [optional] One of: development | production | test. Defaults to development.
NODE_ENV=development
# [optional] HTTP port. Defaults to 3001.
PORT=3001
# [optional] Override pino log level (trace|debug|info|warn|error|fatal).
# Defaults to "debug" in dev, "info" in production.
# LOG_LEVEL=info

# ── Database ────────────────────────────────────────────────────────────
# [required] MongoDB Atlas connection string.
MONGODB_URI=mongodb+srv://...

# ── Sessions ────────────────────────────────────────────────────────────
# [required] 32+ random characters. Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-at-least-32-random-characters

# ── CORS ────────────────────────────────────────────────────────────────
# [required in prod] Comma-separated absolute URLs permitted for browser CORS.
# Example: https://app.chefless.app,https://admin.chefless.app
ALLOWED_ORIGINS=

# ── Firebase (Auth + FCM) ───────────────────────────────────────────────
# [required] Firebase project ID.
FIREBASE_PROJECT_ID=
# [required in prod] Stringified service account JSON (one line).
# Needed for Firebase Admin verification and FCM push. Without it, push is disabled.
FIREBASE_SERVICE_ACCOUNT_KEY=

# ── Cloudinary (image hosting) ──────────────────────────────────────────
# [required]
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── RevenueCat (subscriptions) ──────────────────────────────────────────
# [required] Shared secret validated on POST /api/webhooks/revenuecat.
REVENUECAT_WEBHOOK_SECRET=

# ── Anthropic (AI recipe helper) ────────────────────────────────────────
# [optional] When unset, POST /api/ai/* returns 503.
# ANTHROPIC_API_KEY=

# ── Admin seed (scripts only, not read at runtime) ──────────────────────
# [optional] Consumed by `npm run seed:admin` to create the initial admin.
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
