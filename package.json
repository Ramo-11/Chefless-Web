{
  "name": "chefless-api",
  "version": "1.0.0",
  "description": "Chefless REST API — Node.js + Express + TypeScript",
  "main": "src/index.ts",
  "engines": {
    "node": ">=20.0.0 <23.0.0"
  },
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && cp -r src/views dist/views && cp -r src/public dist/public",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "seed": "tsx src/scripts/seed-labels.ts",
    "seed:admin": "tsx src/scripts/seed-admin.ts",
    "backfill:original-recipes": "tsx src/scripts/backfill-original-recipes-count.ts",
    "backfill:remix-signatures": "tsx src/scripts/backfill-remix-signatures.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-ejs-layouts": "^2.5.4",
    "@types/express-session": "^1.18.2",
    "@types/node": "^22.13.5",
    "bcryptjs": "^3.0.3",
    "cloudinary": "^2.5.1",
    "connect-mongo": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^4.21.2",
    "express-ejs-layouts": "^2.5.1",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.19.0",
    "firebase-admin": "^13.0.2",
    "helmet": "^8.1.0",
    "mongoose": "^8.10.1",
    "pino": "^10.3.1",
    "pino-pretty": "^11.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.9",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  }
}
