<% var pageTitle = 'Analytics'; %>
<% var page = 'analytics'; %>

<div class="page-header">
  <h1>Analytics</h1>
  <p class="page-subtitle">Platform insights and engagement metrics</p>
</div>

<!-- KPI Stats Row -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon stat-icon-blue">
      <i class="fas fa-users"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= activeUsers30d.toLocaleString() %></span>
      <span class="stat-label">Active Users (30d)</span>
    </div>
    <div class="stat-trend stat-trend-up">
      <i class="fas fa-percentage"></i> <%= retention30d %>% of total
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-green">
      <i class="fas fa-book-open"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= recipesThisMonth.toLocaleString() %></span>
      <span class="stat-label">Recipes This Month</span>
    </div>
    <div class="stat-trend stat-trend-up">
      <i class="fas fa-arrow-up"></i> <%= recipesThisWeek %> this week
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-amber">
      <i class="fas fa-crown"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= premiumRate %>%</span>
      <span class="stat-label">Premium Rate</span>
    </div>
    <div class="stat-trend">
      <%= premiumUsers %> of <%= totalUsers %> users
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-purple">
      <i class="fas fa-utensils"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= avgRecipesPerUser %></span>
      <span class="stat-label">Avg Recipes / User</span>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-green">
      <i class="fas fa-heart"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= totalLikes.toLocaleString() %></span>
      <span class="stat-label">Total Likes</span>
    </div>
    <div class="stat-trend">
      <i class="fas fa-chart-line"></i> <%= avgLikes %> avg per recipe
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-blue">
      <i class="fas fa-user-check"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= retention7d %>%</span>
      <span class="stat-label">7-Day Retention</span>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-purple">
      <i class="fas fa-house-chimney"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= totalKitchens.toLocaleString() %></span>
      <span class="stat-label">Kitchens</span>
    </div>
    <div class="stat-trend">
      <i class="fas fa-users"></i> <%= avgMembers %> avg members
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon stat-icon-slate">
      <i class="fas fa-calendar-check"></i>
    </div>
    <div class="stat-content">
      <span class="stat-value"><%= totalScheduleEntries.toLocaleString() %></span>
      <span class="stat-label">Schedule Entries</span>
    </div>
    <div class="stat-trend">
      <i class="fas fa-arrow-up"></i> <%= scheduleEntriesMonth %> this month
    </div>
  </div>
</div>

<!-- Social Stats Row -->
<div class="analytics-metric-row">
  <div class="metric-pill">
    <i class="fas fa-code-branch"></i>
    <span><strong><%= totalForks.toLocaleString() %></strong> remixes</span>
  </div>
  <div class="metric-pill">
    <i class="fas fa-user-plus"></i>
    <span><strong><%= totalFollows.toLocaleString() %></strong> follows</span>
  </div>
  <div class="metric-pill">
    <i class="fas fa-user-group"></i>
    <span><strong><%= avgFollowers %></strong> avg followers/user</span>
  </div>
  <div class="metric-pill">
    <i class="fas fa-clipboard-check"></i>
    <span><strong><%= onboardingCompleted.toLocaleString() %></strong> onboarded</span>
  </div>
  <div class="metric-pill">
    <i class="fas fa-camera"></i>
    <span><strong><%= recipeBasedEntries.toLocaleString() %></strong> recipe-based schedules</span>
  </div>
  <div class="metric-pill">
    <i class="fas fa-pencil"></i>
    <span><strong><%= freeformEntries.toLocaleString() %></strong> freeform schedules</span>
  </div>
  <div class="metric-pill metric-pill-alert">
    <i class="fas fa-ban"></i>
    <span><strong><%= bannedUsers %></strong> banned</span>
  </div>
  <div class="metric-pill metric-pill-alert">
    <i class="fas fa-eye-slash"></i>
    <span><strong><%= hiddenRecipes %></strong> hidden recipes</span>
  </div>
</div>

<!-- Charts Grid -->
<div class="analytics-charts-grid">
  <!-- User Growth -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-user-plus"></i> User Growth</h3>
      <span class="chart-card-subtitle">Daily signups, last 30 days</span>
    </div>
    <div class="chart-container">
      <canvas id="signupsChart"></canvas>
    </div>
  </div>

  <!-- Recipe Creation -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-book-open"></i> Recipe Creation</h3>
      <span class="chart-card-subtitle">Daily new recipes, last 30 days</span>
    </div>
    <div class="chart-container">
      <canvas id="recipesChart"></canvas>
    </div>
  </div>

  <!-- Dietary Tags -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-leaf"></i> Dietary Tags</h3>
      <span class="chart-card-subtitle">Top 10 recipe tags</span>
    </div>
    <div class="chart-container chart-container-doughnut">
      <canvas id="dietaryChart"></canvas>
    </div>
  </div>

  <!-- Meal Slot Distribution -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-clock"></i> Meal Slots</h3>
      <span class="chart-card-subtitle">Schedule entries by meal type</span>
    </div>
    <div class="chart-container chart-container-doughnut">
      <canvas id="mealSlotChart"></canvas>
    </div>
  </div>

  <!-- Premium Breakdown -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-crown"></i> Premium Breakdown</h3>
      <span class="chart-card-subtitle">User subscription types</span>
    </div>
    <div class="chart-container chart-container-doughnut">
      <canvas id="premiumChart"></canvas>
    </div>
  </div>

  <!-- Schedule Trend -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-calendar-alt"></i> Schedule Trend</h3>
      <span class="chart-card-subtitle">Weekly entries, last 12 weeks</span>
    </div>
    <div class="chart-container">
      <canvas id="scheduleChart"></canvas>
    </div>
  </div>

  <!-- Report Status -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-flag"></i> Report Status</h3>
      <span class="chart-card-subtitle">Reports by current status</span>
    </div>
    <div class="chart-container chart-container-doughnut">
      <canvas id="reportStatusChart"></canvas>
    </div>
  </div>

  <!-- Report Reasons -->
  <div class="chart-card">
    <div class="chart-card-header">
      <h3><i class="fas fa-exclamation-triangle"></i> Report Reasons</h3>
      <span class="chart-card-subtitle">Why content gets reported</span>
    </div>
    <div class="chart-container chart-container-doughnut">
      <canvas id="reportReasonChart"></canvas>
    </div>
  </div>
</div>

<!-- Tables -->
<div class="analytics-tables-grid">
  <!-- Top Most Liked Recipes -->
  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-heart"></i> Most Liked Recipes</h2>
    </div>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Recipe</th>
            <th>Author</th>
            <th>Likes</th>
            <th>Remixes</th>
          </tr>
        </thead>
        <tbody>
          <% topLikedRecipes.forEach(function(recipe, i) { %>
          <tr>
            <td class="text-muted"><%= i + 1 %></td>
            <td><strong><%= recipe.title %></strong></td>
            <td class="text-muted"><%= recipe.authorName %></td>
            <td><span class="badge badge-default"><i class="fas fa-heart"></i> <%= recipe.likesCount %></span></td>
            <td><span class="badge badge-default"><i class="fas fa-code-branch"></i> <%= recipe.forksCount %></span></td>
          </tr>
          <% }); %>
          <% if (topLikedRecipes.length === 0) { %>
          <tr><td colspan="5" class="empty-state">No liked recipes yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Top Most Remixed Recipes -->
  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-code-branch"></i> Most Remixed Recipes</h2>
    </div>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>Recipe</th>
            <th>Author</th>
            <th>Remixes</th>
            <th>Likes</th>
          </tr>
        </thead>
        <tbody>
          <% topRemixedRecipes.forEach(function(recipe, i) { %>
          <tr>
            <td class="text-muted"><%= i + 1 %></td>
            <td><strong><%= recipe.title %></strong></td>
            <td class="text-muted"><%= recipe.authorName %></td>
            <td><span class="badge badge-default"><i class="fas fa-code-branch"></i> <%= recipe.forksCount %></span></td>
            <td><span class="badge badge-default"><i class="fas fa-heart"></i> <%= recipe.likesCount %></span></td>
          </tr>
          <% }); %>
          <% if (topRemixedRecipes.length === 0) { %>
          <tr><td colspan="5" class="empty-state">No remixed recipes yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Top Most Active Users -->
  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-trophy"></i> Most Active Users</h2>
    </div>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Email</th>
            <th>Recipes</th>
            <th>Followers</th>
          </tr>
        </thead>
        <tbody>
          <% topActiveUsers.forEach(function(user, i) { %>
          <tr>
            <td class="text-muted"><%= i + 1 %></td>
            <td><strong><%= user.fullName %></strong></td>
            <td class="text-muted"><%= user.email %></td>
            <td><%= user.recipesCount %></td>
            <td><%= user.followersCount %></td>
          </tr>
          <% }); %>
          <% if (topActiveUsers.length === 0) { %>
          <tr><td colspan="5" class="empty-state">No users yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Most Followed Users -->
  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-star"></i> Most Followed Users</h2>
    </div>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>#</th>
            <th>User</th>
            <th>Email</th>
            <th>Followers</th>
            <th>Recipes</th>
          </tr>
        </thead>
        <tbody>
          <% mostFollowedUsers.forEach(function(user, i) { %>
          <tr>
            <td class="text-muted"><%= i + 1 %></td>
            <td><strong><%= user.fullName %></strong></td>
            <td class="text-muted"><%= user.email %></td>
            <td><%= user.followersCount %></td>
            <td><%= user.recipesCount %></td>
          </tr>
          <% }); %>
          <% if (mostFollowedUsers.length === 0) { %>
          <tr><td colspan="5" class="empty-state">No users yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- Chart.js CDN -->
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>

<script>
(function() {
  // ── Color palette ──
  var COLORS = {
    terracotta: '#C45C3A',
    gold: '#D4920B',
    green: '#10b981',
    blue: '#3b82f6',
    purple: '#8b5cf6',
    amber: '#f59e0b',
    pink: '#ec4899',
    teal: '#14b8a6'
  };
  var PALETTE = [
    COLORS.terracotta, COLORS.gold, COLORS.green, COLORS.blue,
    COLORS.purple, COLORS.amber, COLORS.pink, COLORS.teal,
    '#6366f1', '#ef4444'
  ];

  // ── Chart defaults ──
  Chart.defaults.font.family = "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif";
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#64748b';
  Chart.defaults.plugins.legend.labels.usePointStyle = true;
  Chart.defaults.plugins.legend.labels.pointStyleWidth = 8;
  Chart.defaults.plugins.legend.labels.padding = 16;

  // ── Data from server ──
  var signupsData = <%- JSON.stringify(signupsChartData) %>;
  var recipesData = <%- JSON.stringify(recipesChartData) %>;
  var dietaryTags = <%- JSON.stringify(dietaryTagDistribution) %>;
  var mealSlots = <%- JSON.stringify(mealSlotDistribution) %>;
  var scheduleData = <%- JSON.stringify(scheduleChartData) %>;
  var reportStatuses = <%- JSON.stringify(reportsByStatus) %>;
  var reportReasons = <%- JSON.stringify(reportsByReason) %>;

  var premiumBreakdown = {
    labels: ['Free', 'Monthly', 'Annual', 'Promo'],
    data: [<%= freeUsers %>, <%= premiumMonthly %>, <%= premiumAnnual %>, <%= premiumPromo %>]
  };

  // ── Helper: format date label (Jan 5) ──
  function shortDate(isoStr) {
    var d = new Date(isoStr + 'T00:00:00');
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  // ── 1. User Growth (Line) ──
  new Chart(document.getElementById('signupsChart'), {
    type: 'line',
    data: {
      labels: signupsData.map(function(d) { return shortDate(d.date); }),
      datasets: [{
        label: 'New Users',
        data: signupsData.map(function(d) { return d.count; }),
        borderColor: COLORS.blue,
        backgroundColor: 'rgba(59, 130, 246, 0.08)',
        fill: true,
        tension: 0.35,
        pointRadius: 2,
        pointHoverRadius: 5,
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { maxTicksLimit: 8 } },
        y: { beginAtZero: true, ticks: { precision: 0 } }
      }
    }
  });

  // ── 2. Recipe Creation (Line) ──
  new Chart(document.getElementById('recipesChart'), {
    type: 'line',
    data: {
      labels: recipesData.map(function(d) { return shortDate(d.date); }),
      datasets: [{
        label: 'New Recipes',
        data: recipesData.map(function(d) { return d.count; }),
        borderColor: COLORS.green,
        backgroundColor: 'rgba(16, 185, 129, 0.08)',
        fill: true,
        tension: 0.35,
        pointRadius: 2,
        pointHoverRadius: 5,
        borderWidth: 2
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false }, ticks: { maxTicksLimit: 8 } },
        y: { beginAtZero: true, ticks: { precision: 0 } }
      }
    }
  });

  // ── 3. Dietary Tags (Doughnut) ──
  if (dietaryTags.length > 0) {
    new Chart(document.getElementById('dietaryChart'), {
      type: 'doughnut',
      data: {
        labels: dietaryTags.map(function(t) { return t.tag; }),
        datasets: [{
          data: dietaryTags.map(function(t) { return t.count; }),
          backgroundColor: PALETTE.slice(0, dietaryTags.length),
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '60%',
        plugins: {
          legend: { position: 'right', labels: { boxWidth: 12 } }
        }
      }
    });
  } else {
    document.getElementById('dietaryChart').parentElement.innerHTML =
      '<div class="chart-empty">No dietary tag data</div>';
  }

  // ── 4. Meal Slot Distribution (Doughnut) ──
  if (mealSlots.length > 0) {
    new Chart(document.getElementById('mealSlotChart'), {
      type: 'doughnut',
      data: {
        labels: mealSlots.map(function(s) { return s._id; }),
        datasets: [{
          data: mealSlots.map(function(s) { return s.count; }),
          backgroundColor: [COLORS.gold, COLORS.terracotta, COLORS.teal, COLORS.purple, COLORS.amber, COLORS.pink, COLORS.blue, COLORS.green],
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '60%',
        plugins: {
          legend: { position: 'right', labels: { boxWidth: 12 } }
        }
      }
    });
  } else {
    document.getElementById('mealSlotChart').parentElement.innerHTML =
      '<div class="chart-empty">No schedule data</div>';
  }

  // ── 5. Premium Breakdown (Doughnut) ──
  new Chart(document.getElementById('premiumChart'), {
    type: 'doughnut',
    data: {
      labels: premiumBreakdown.labels,
      datasets: [{
        data: premiumBreakdown.data,
        backgroundColor: ['#e2e8f0', COLORS.blue, COLORS.purple, COLORS.amber],
        borderWidth: 0,
        hoverOffset: 6
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      cutout: '60%',
      plugins: {
        legend: { position: 'right', labels: { boxWidth: 12 } }
      }
    }
  });

  // ── 6. Schedule Trend (Bar) ──
  new Chart(document.getElementById('scheduleChart'), {
    type: 'bar',
    data: {
      labels: scheduleData.map(function(d) { return d.week; }),
      datasets: [{
        label: 'Entries',
        data: scheduleData.map(function(d) { return d.count; }),
        backgroundColor: COLORS.terracotta,
        borderRadius: 4,
        borderSkipped: false,
        barPercentage: 0.7
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { grid: { display: false } },
        y: { beginAtZero: true, ticks: { precision: 0 } }
      }
    }
  });

  // ── 7. Report Status (Doughnut) ──
  if (reportStatuses.length > 0) {
    var statusColors = {
      pending: COLORS.amber,
      reviewed: COLORS.blue,
      dismissed: '#94a3b8',
      action_taken: COLORS.terracotta
    };
    new Chart(document.getElementById('reportStatusChart'), {
      type: 'doughnut',
      data: {
        labels: reportStatuses.map(function(s) { return s.status.replace('_', ' '); }),
        datasets: [{
          data: reportStatuses.map(function(s) { return s.count; }),
          backgroundColor: reportStatuses.map(function(s) { return statusColors[s.status] || '#94a3b8'; }),
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '60%',
        plugins: {
          legend: { position: 'right', labels: { boxWidth: 12 } }
        }
      }
    });
  } else {
    document.getElementById('reportStatusChart').parentElement.innerHTML =
      '<div class="chart-empty">No reports</div>';
  }

  // ── 8. Report Reasons (Doughnut) ──
  if (reportReasons.length > 0) {
    new Chart(document.getElementById('reportReasonChart'), {
      type: 'doughnut',
      data: {
        labels: reportReasons.map(function(r) { return r.reason; }),
        datasets: [{
          data: reportReasons.map(function(r) { return r.count; }),
          backgroundColor: PALETTE.slice(0, reportReasons.length),
          borderWidth: 0,
          hoverOffset: 6
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '60%',
        plugins: {
          legend: { position: 'right', labels: { boxWidth: 12 } }
        }
      }
    });
  } else {
    document.getElementById('reportReasonChart').parentElement.innerHTML =
      '<div class="chart-empty">No reports</div>';
  }
})();
</script>

<style>
/* ── Analytics-specific styles ─────────────────────────────── */

.analytics-metric-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 2rem;
}

.metric-pill {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--surface);
  border: 1px solid var(--border-color);
  border-radius: 999px;
  padding: 0.5rem 1rem;
  font-size: 0.825rem;
  color: var(--text-secondary);
  transition: box-shadow 0.15s;
}

.metric-pill:hover {
  box-shadow: var(--shadow-sm);
}

.metric-pill i {
  color: var(--text-muted);
  font-size: 0.8rem;
}

.metric-pill strong {
  color: var(--text-primary);
  font-weight: 700;
}

.metric-pill-alert {
  border-color: var(--danger);
  background: var(--danger-light);
}

.metric-pill-alert i {
  color: var(--danger);
}

.analytics-charts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(450px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.chart-card {
  background: var(--surface);
  border: 1px solid var(--border-color);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.chart-card-header {
  padding: 1rem 1.25rem;
  border-bottom: 1px solid var(--border-color);
}

.chart-card-header h3 {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.chart-card-header h3 i {
  color: var(--text-muted);
}

.chart-card-subtitle {
  font-size: 0.8rem;
  color: var(--text-muted);
  margin-top: 0.15rem;
  display: block;
}

.chart-container {
  padding: 1.25rem;
  height: 260px;
  position: relative;
}

.chart-container-doughnut {
  height: 280px;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: var(--text-muted);
  font-size: 0.875rem;
}

.analytics-tables-grid {
  display: grid;
