<% var pageTitle = 'Kitchens'; %>
<% var page = 'kitchens'; %>

<div class="page-header">
  <h1>Kitchen Management</h1>
  <p class="page-subtitle"><%= pagination.totalItems.toLocaleString() %> total kitchens</p>
</div>

<!-- Toolbar -->
<div class="toolbar">
  <form action="/admin/kitchens" method="GET" class="toolbar-search">
    <div class="input-with-icon">
      <i class="fas fa-search"></i>
      <input type="text" name="search" value="<%= search %>" placeholder="Search by kitchen name...">
    </div>
    <button type="submit" class="btn btn-primary btn-sm">Search</button>
  </form>
</div>

<!-- Kitchens Table -->
<div class="card">
  <div class="table-responsive">
    <table class="data-table">
      <thead>
        <tr>
          <th>Kitchen</th>
          <th>Lead</th>
          <th>Members</th>
          <th>Invite Code</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% kitchens.forEach(function(kitchen) { %>
        <tr data-kitchen-id="<%= kitchen._id %>">
          <td>
            <strong><%= kitchen.name %></strong>
          </td>
          <td>
            <% if (kitchen.leadId && kitchen.leadId.fullName) { %>
              <%= kitchen.leadId.fullName %>
            <% } else { %>
              <span class="text-muted">Unknown</span>
            <% } %>
          </td>
          <td><%= kitchen.memberCount %></td>
          <td><code><%= kitchen.inviteCode %></code></td>
          <td class="text-muted"><%= new Date(kitchen.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></td>
          <td>
            <div class="action-buttons">
              <button class="btn btn-sm btn-secondary" onclick="viewKitchen('<%= kitchen._id %>')" aria-label="View kitchen details">
                <i class="fas fa-eye"></i>
              </button>
              <button class="btn btn-sm btn-secondary" onclick="editKitchen('<%= kitchen._id %>')" aria-label="Edit kitchen">
                <i class="fas fa-pencil"></i>
              </button>
              <button class="btn btn-sm btn-danger-outline" onclick="confirmDeleteKitchen('<%= kitchen._id %>', '<%= kitchen.name.replace(/'/g, "\\'") %>')" aria-label="Delete kitchen">
                <i class="fas fa-trash"></i>
              </button>
            </div>
          </td>
        </tr>
        <% }); %>
        <% if (kitchens.length === 0) { %>
        <tr>
          <td colspan="6" class="empty-state">
            <i class="fas fa-search"></i>
            <span>No kitchens found</span>
          </td>
        </tr>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<!-- Pagination -->
<% if (pagination.total > 1) { %>
  <%- include('partials/pagination', { pagination, baseUrl: '/admin/kitchens?search=' + search }) %>
<% } %>

<!-- Kitchen Detail Modal -->
<div class="modal" id="kitchen-detail-modal">
  <div class="modal-content modal-lg">
    <div class="modal-header">
      <h2>Kitchen Details</h2>
      <button class="modal-close" onclick="closeModal('kitchen-detail-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body" id="kitchen-detail-body">
      <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
    </div>
  </div>
</div>

<!-- Edit Kitchen Modal -->
<div class="modal" id="edit-kitchen-modal">
  <div class="modal-content modal-sm">
    <div class="modal-header">
      <h2>Edit Kitchen</h2>
      <button class="modal-close" onclick="closeModal('edit-kitchen-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-kitchen-id">
      <div class="form-group">
        <label for="edit-kitchen-name">Name</label>
        <input type="text" id="edit-kitchen-name" placeholder="Kitchen name">
      </div>
      <div class="form-group">
        <label for="edit-kitchen-photo">Photo URL</label>
        <input type="text" id="edit-kitchen-photo" placeholder="https://...">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('edit-kitchen-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="saveKitchen()">Save Changes</button>
    </div>
  </div>
</div>

<!-- Delete Kitchen Modal -->
<div class="modal" id="delete-kitchen-modal">
  <div class="modal-content modal-sm">
    <div class="modal-header">
      <h2>Delete Kitchen</h2>
      <button class="modal-close" onclick="closeModal('delete-kitchen-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <p>Are you sure you want to delete <strong id="delete-kitchen-name"></strong>? This will remove all members, schedule entries, and shopping lists associated with this kitchen. This action cannot be undone.</p>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('delete-kitchen-modal')">Cancel</button>
      <button class="btn btn-danger" onclick="deleteKitchen()">Confirm Delete</button>
    </div>
  </div>
</div>

<script>
  let editingKitchenId = null;
  let deletingKitchenId = null;

  function viewKitchen(id) {
    openModal('kitchen-detail-modal');
    document.getElementById('kitchen-detail-body').innerHTML = '<div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>';
    Promise.all([
      adminFetch('/admin/api/kitchens/' + id),
      adminFetch('/admin/api/kitchens/' + id + '/suggestions').catch(() => ({ suggestions: [] })),
    ])
      .then(([data, suggestionsData]) => {
        const k = data.kitchen;
        const members = data.members || [];
        const suggestions = (suggestionsData && suggestionsData.suggestions) || [];
        const leadId = k.leadId ? (k.leadId._id || k.leadId) : null;
        const leadIdStr = leadId ? leadId.toString() : '';

        let membersHtml = '';
        if (members.length > 0) {
          membersHtml = `
            <div class="detail-section">
              <h4>Members (${members.length})</h4>
              <div class="table-responsive">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Member</th>
                      <th>Email</th>
                      <th>Role</th>
                      <th>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${members.map(m => {
                      const mIdStr = (m._id || '').toString();
                      const isLead = mIdStr === leadIdStr;
                      return `
                        <tr>
                          <td>
                            <div class="user-cell">
                              ${m.profilePicture ? `<img src="${esc(m.profilePicture)}" alt="" class="avatar-sm">` : `<div class="avatar-sm avatar-placeholder">${esc(m.fullName).charAt(0).toUpperCase()}</div>`}
                              <span>${esc(m.fullName)}</span>
                            </div>
                          </td>
                          <td class="text-muted">${esc(m.email)}</td>
                          <td>${isLead ? '<span class="badge badge-info">Lead</span>' : '<span class="badge badge-default">Member</span>'}</td>
                          <td>
                            <div class="action-buttons">
                              ${!isLead ? `<button class="btn btn-sm btn-danger-outline" onclick="removeMember('${esc(k._id)}', '${esc(mIdStr)}', '${esc(m.fullName)}')" aria-label="Remove member"><i class="fas fa-user-minus"></i></button>` : ''}
                              ${!isLead ? `<button class="btn btn-sm btn-secondary" onclick="transferLead('${esc(k._id)}', '${esc(mIdStr)}', '${esc(m.fullName)}')" aria-label="Transfer lead"><i class="fas fa-crown"></i></button>` : ''}
                            </div>
                          </td>
                        </tr>
                      `;
                    }).join('')}
                  </tbody>
                </table>
              </div>
            </div>
          `;
        } else {
          membersHtml = '<div class="detail-section"><h4>Members</h4><p class="text-muted">No members found</p></div>';
        }

        const policyLabel = k.scheduleAddPolicy === 'all'
          ? 'All members (direct)'
          : 'Lead only (others suggest)';

        let suggestionsHtml = '';
        if (suggestions.length > 0) {
          suggestionsHtml = `
            <div class="detail-section">
              <h4>Pending Suggestions (${suggestions.length})</h4>
              <div class="table-responsive">
                <table class="data-table">
                  <thead>
                    <tr>
                      <th>Meal</th>
                      <th>Slot</th>
                      <th>Date</th>
                      <th>Suggested by</th>
                      <th>Submitted</th>
                    </tr>
                  </thead>
                  <tbody>
                    ${suggestions.map(s => {
                      const suggester = s.suggestedBy && s.suggestedBy.fullName
                        ? esc(s.suggestedBy.fullName)
                        : '<span class="text-muted">Unknown</span>';
                      const meal = esc(s.recipeTitle || s.freeformText || 'Untitled');
                      const slotRaw = (s.mealSlot || '').toString();
                      const slot = slotRaw
                        ? esc(slotRaw.charAt(0).toUpperCase() + slotRaw.slice(1))
                        : '<span class="text-muted">—</span>';
                      const dateStr = s.date
                        ? new Date(s.date).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
                        : '—';
                      const submittedStr = s.createdAt
                        ? new Date(s.createdAt).toLocaleString('en-US', { month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit' })
                        : '—';
                      return `
                        <tr>
                          <td>${meal}</td>
                          <td>${slot}</td>
                          <td class="text-muted">${dateStr}</td>
                          <td>${suggester}</td>
                          <td class="text-muted">${submittedStr}</td>
                        </tr>
                      `;
                    }).join('')}
                  </tbody>
                </table>
              </div>
            </div>
          `;
        } else {
          suggestionsHtml = '<div class="detail-section"><h4>Pending Suggestions</h4><p class="text-muted">No pending suggestions</p></div>';
        }

        const photoHtml = k.photo
          ? `<div class="detail-section">
              <h4>Photo</h4>
              <div style="display: flex; gap: 12px; align-items: flex-start;">
                <img src="${esc(k.photo)}" alt="Kitchen photo" style="width: 96px; height: 96px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-color, #e5e7eb);">
                <button class="btn btn-sm btn-danger-outline" onclick="removeKitchenPhoto('${esc(k._id)}')" aria-label="Remove kitchen photo">
                  <i class="fas fa-trash"></i> Remove photo
                </button>
              </div>
             </div>`
          : '';

        document.getElementById('kitchen-detail-body').innerHTML = `
          <div class="detail-grid">
            <div class="detail-section">
              <h4>Kitchen Info</h4>
              <div class="detail-row"><span>Name:</span> <span>${esc(k.name)}</span></div>
              <div class="detail-row"><span>Lead:</span> <span>${k.leadId && k.leadId.fullName ? esc(k.leadId.fullName) : 'Unknown'}</span></div>
              <div class="detail-row"><span>Invite Code:</span> <span><code>${esc(k.inviteCode)}</code></span></div>
              <div class="detail-row"><span>Member Count:</span> <span>${Number(k.memberCount) || 0}</span></div>
              <div class="detail-row"><span>Schedule Policy:</span> <span>${esc(policyLabel)}</span></div>
              <div class="detail-row"><span>Created:</span> <span>${new Date(k.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span></div>
            </div>
            ${photoHtml}
            ${membersHtml}
            ${suggestionsHtml}
          </div>
        `;
      })
      .catch(() => {
        document.getElementById('kitchen-detail-body').innerHTML = '<p class="text-error">Failed to load kitchen details.</p>';
      });
  }

  function editKitchen(id) {
    adminFetch('/admin/api/kitchens/' + id)
      .then(data => {
        const k = data.kitchen;
        editingKitchenId = id;
        document.getElementById('edit-kitchen-id').value = id;
        document.getElementById('edit-kitchen-name').value = k.name || '';
        document.getElementById('edit-kitchen-photo').value = k.photo || '';
        openModal('edit-kitchen-modal');
      })
      .catch(() => showToast('Failed to load kitchen', 'error'));
  }

  function saveKitchen() {
    if (!editingKitchenId) return;
    const name = document.getElementById('edit-kitchen-name').value.trim();
    const photo = document.getElementById('edit-kitchen-photo').value.trim();

    if (!name) {
      showToast('Kitchen name is required', 'error');
      return;
    }

    const body = { name };
    if (photo) body.photo = photo;

    adminFetch('/admin/api/kitchens/' + editingKitchenId, {
      method: 'PUT',
      body: JSON.stringify(body)
    })
    .then(() => {
      closeModal('edit-kitchen-modal');
      toastAndReload('Kitchen updated successfully');
    })
    .catch(() => showToast('Failed to update kitchen', 'error'));
  }

  function removeMember(kitchenId, memberId, memberName) {
    if (!confirm('Are you sure you want to remove ' + memberName + ' from this kitchen?')) return;
    adminFetch('/admin/api/kitchens/' + kitchenId + '/remove-member', {
      method: 'POST',
      body: JSON.stringify({ memberId })
    })
    .then(() => {
      closeModal('kitchen-detail-modal');
      toastAndReload('Member removed successfully');
    })
    .catch(() => showToast('Failed to remove member', 'error'));
  }

  function removeKitchenPhoto(kitchenId) {
    if (!confirm('Remove this kitchen photo? The Cloudinary asset will be permanently deleted.')) return;
    adminFetch('/admin/api/kitchens/' + kitchenId + '/photo', {
      method: 'DELETE'
    })
    .then(() => {
      closeModal('kitchen-detail-modal');
      toastAndReload('Kitchen photo removed');
    })
    .catch(() => showToast('Failed to remove photo', 'error'));
  }

  function transferLead(kitchenId, memberId, memberName) {
    if (!confirm('Are you sure you want to transfer kitchen lead to ' + memberName + '?')) return;
    adminFetch('/admin/api/kitchens/' + kitchenId + '/transfer-lead', {
      method: 'POST',
      body: JSON.stringify({ newLeadId: memberId })
    })
    .then(() => {
      closeModal('kitchen-detail-modal');
      toastAndReload('Kitchen lead transferred successfully');
    })
    .catch(() => showToast('Failed to transfer lead', 'error'));
  }

  function confirmDeleteKitchen(id, name) {
    deletingKitchenId = id;
    document.getElementById('delete-kitchen-name').textContent = name;
    openModal('delete-kitchen-modal');
  }

  function deleteKitchen() {
    if (!deletingKitchenId) return;
    adminFetch('/admin/api/kitchens/' + deletingKitchenId, {
      method: 'DELETE'
    })
    .then(() => {
      closeModal('delete-kitchen-modal');
      toastAndReload('Kitchen deleted successfully');
    })
    .catch(() => showToast('Failed to delete kitchen', 'error'));
  }
</script>
