<% var pageTitle = 'Promo Codes'; %>
<% var page = 'promo-codes'; %>

<div class="page-header">
  <h1>Promo Codes</h1>
  <p class="page-subtitle">Create and manage discount codes that grant premium access</p>
</div>

<div class="content-split">
  <!-- Promo Codes Table -->
  <div class="card card-flex">
    <div class="card-header">
      <h2>All Codes</h2>
    </div>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Code</th>
            <th>Description</th>
            <th>Duration</th>
            <th>Usage</th>
            <th>Status</th>
            <th>Valid Period</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% promoCodes.forEach(function(pc) { %>
          <%
            var now = new Date();
            var isExpired = new Date(pc.validUntil) < now;
            var statusClass = isExpired ? 'badge-default' : (pc.isActive ? 'badge-success' : 'badge-default');
            var statusText = isExpired ? 'Expired' : (pc.isActive ? 'Active' : 'Inactive');
            var usage = pc.redemptionCount + '/' + (pc.maxRedemptions === 0 ? '\u221E' : pc.maxRedemptions);
          %>
          <tr id="promo-<%= pc._id %>">
            <td>
              <strong style="font-family: monospace; font-size: 0.95rem; letter-spacing: 0.5px;"><%= pc.code %></strong>
            </td>
            <td class="text-muted" style="max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="<%= pc.description %>"><%= pc.description %></td>
            <td><%= pc.durationDays %> day<%= pc.durationDays !== 1 ? 's' : '' %></td>
            <td><span class="order-badge"><%= usage %></span></td>
            <td><span class="badge <%= statusClass %>"><%= statusText %></span></td>
            <td class="text-muted text-sm">
              <%= new Date(pc.validFrom).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
              &ndash;
              <%= new Date(pc.validUntil).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
            </td>
            <td>
              <div class="action-buttons">
                <button class="btn btn-sm btn-secondary" onclick="viewPromoCode('<%= pc._id %>')" aria-label="View details" title="View details">
                  <i class="fas fa-eye"></i>
                </button>
                <button class="btn btn-sm btn-primary" onclick="editPromoCode('<%= pc._id %>')" aria-label="Edit" title="Edit">
                  <i class="fas fa-edit"></i>
                </button>
                <button class="btn btn-sm btn-secondary" onclick="togglePromoCode('<%= pc._id %>', <%= pc.isActive %>)" aria-label="Toggle active" title="<%= pc.isActive ? 'Deactivate' : 'Activate' %>">
                  <i class="fas fa-<%= pc.isActive ? 'pause' : 'play' %>"></i>
                </button>
                <button class="btn btn-sm btn-danger-outline" onclick="deletePromoCode('<%= pc._id %>', '<%= pc.code %>')" aria-label="Delete" title="Delete">
                  <i class="fas fa-trash"></i>
                </button>
              </div>
            </td>
          </tr>
          <% }); %>
          <% if (promoCodes.length === 0) { %>
          <tr>
            <td colspan="7" class="empty-state">No promo codes yet. Create one to get started.</td>
          </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Create Promo Code Form -->
  <div class="card card-form">
    <div class="card-header">
      <h2>Create Code</h2>
    </div>
    <div class="card-body">
      <div class="form-group">
        <label for="new-code">Code</label>
        <input type="text" id="new-code" placeholder="e.g. LAUNCH2026" maxlength="20" style="text-transform: uppercase; font-family: monospace;">
      </div>
      <div class="form-group">
        <label for="new-description">Description</label>
        <textarea id="new-description" rows="2" placeholder="Admin-facing note about this code..."></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="new-duration">Duration (days)</label>
          <input type="number" id="new-duration" value="30" min="1">
        </div>
        <div class="form-group">
          <label for="new-max-redemptions">Max Redemptions</label>
          <input type="number" id="new-max-redemptions" value="0" min="0">
          <small class="text-muted">0 = unlimited</small>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="new-valid-from">Valid From</label>
          <input type="date" id="new-valid-from">
        </div>
        <div class="form-group">
          <label for="new-valid-until">Valid Until</label>
          <input type="date" id="new-valid-until">
        </div>
      </div>
      <button class="btn btn-primary btn-block" onclick="createPromoCode()">
        <i class="fas fa-plus"></i> Create Code
      </button>
    </div>
  </div>
</div>

<!-- Detail Modal -->
<div class="modal" id="promo-detail-modal">
  <div class="modal-content modal-lg">
    <div class="modal-header">
      <h2>Promo Code Details</h2>
      <button class="modal-close" onclick="closeModal('promo-detail-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body" id="promo-detail-body">
      <div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>
    </div>
  </div>
</div>

<!-- Edit Modal -->
<div class="modal" id="promo-edit-modal">
  <div class="modal-content modal-sm">
    <div class="modal-header">
      <h2>Edit Promo Code</h2>
      <button class="modal-close" onclick="closeModal('promo-edit-modal')" aria-label="Close">&times;</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="edit-promo-id">
      <div class="form-group">
        <label for="edit-description">Description</label>
        <textarea id="edit-description" rows="2"></textarea>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="edit-duration">Duration (days)</label>
          <input type="number" id="edit-duration" min="1">
        </div>
        <div class="form-group">
          <label for="edit-max-redemptions">Max Redemptions</label>
          <input type="number" id="edit-max-redemptions" min="0">
          <small class="text-muted">0 = unlimited</small>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="edit-valid-from">Valid From</label>
          <input type="date" id="edit-valid-from">
        </div>
        <div class="form-group">
          <label for="edit-valid-until">Valid Until</label>
          <input type="date" id="edit-valid-until">
        </div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-secondary" onclick="closeModal('promo-edit-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="savePromoCode()">Save Changes</button>
    </div>
  </div>
</div>

<script>
  // Set default dates for the create form
  (function() {
    var today = new Date();
    var inOneMonth = new Date(today);
    inOneMonth.setMonth(inOneMonth.getMonth() + 1);
    document.getElementById('new-valid-from').value = today.toISOString().split('T')[0];
    document.getElementById('new-valid-until').value = inOneMonth.toISOString().split('T')[0];
  })();

  function createPromoCode() {
    var code = document.getElementById('new-code').value.trim().toUpperCase();
    var description = document.getElementById('new-description').value.trim();
    var durationDays = document.getElementById('new-duration').value;
    var maxRedemptions = document.getElementById('new-max-redemptions').value;
    var validFrom = document.getElementById('new-valid-from').value;
    var validUntil = document.getElementById('new-valid-until').value;

    if (!code || !description || !durationDays || !validFrom || !validUntil) {
      showToast('All fields are required', 'error');
      return;
    }

    adminFetch('/admin/api/promo-codes', {
      method: 'POST',
      body: JSON.stringify({ code, description, durationDays, maxRedemptions, validFrom, validUntil })
    })
    .then(function() { toastAndReload('Promo code created'); })
    .catch(function(e) { showToast(e.message || 'Failed to create promo code', 'error'); });
  }

  function viewPromoCode(id) {
    openModal('promo-detail-modal');
    var body = document.getElementById('promo-detail-body');
    body.innerHTML = '<div class="loading-spinner"><i class="fas fa-spinner fa-spin"></i></div>';

    adminFetch('/admin/api/promo-codes/' + id)
      .then(function(data) {
        var pc = data.promoCode;
        var redemptions = data.redemptions || [];
        var usage = pc.redemptionCount + '/' + (pc.maxRedemptions === 0 ? '\u221E' : pc.maxRedemptions);

        var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1.5rem;">';
        html += '<div><strong>Code</strong><br><span style="font-family:monospace;font-size:1.1rem;">' + esc(pc.code) + '</span></div>';
        html += '<div><strong>Status</strong><br>' + (pc.isActive ? '<span class="badge badge-success">Active</span>' : '<span class="badge badge-default">Inactive</span>') + '</div>';
        html += '<div><strong>Description</strong><br>' + esc(pc.description) + '</div>';
        html += '<div><strong>Duration</strong><br>' + pc.durationDays + ' day' + (pc.durationDays !== 1 ? 's' : '') + '</div>';
        html += '<div><strong>Usage</strong><br>' + usage + '</div>';
        html += '<div><strong>Valid Period</strong><br>' + new Date(pc.validFrom).toLocaleDateString() + ' \u2013 ' + new Date(pc.validUntil).toLocaleDateString() + '</div>';
        html += '</div>';

        html += '<h3 style="margin-bottom:0.75rem;">Redemption History (' + redemptions.length + ')</h3>';
        if (redemptions.length > 0) {
          html += '<div class="table-responsive"><table class="data-table"><thead><tr>';
          html += '<th>User</th><th>Email</th><th>Redeemed</th><th>Premium Until</th>';
          html += '</tr></thead><tbody>';
          redemptions.forEach(function(r) {
            var user = r.userId || {};
            html += '<tr>';
            html += '<td>' + esc(user.fullName || 'Deleted User') + '</td>';
            html += '<td class="text-muted">' + esc(user.email || '\u2014') + '</td>';
            html += '<td>' + new Date(r.redeemedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + '</td>';
            html += '<td>' + new Date(r.premiumGrantedUntil).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) + '</td>';
            html += '</tr>';
          });
          html += '</tbody></table></div>';
        } else {
          html += '<p class="text-muted">No redemptions yet.</p>';
        }

        body.innerHTML = html;
      })
      .catch(function() {
        body.innerHTML = '<p class="text-muted">Failed to load details.</p>';
      });
  }

  function editPromoCode(id) {
    adminFetch('/admin/api/promo-codes/' + id)
      .then(function(data) {
        var pc = data.promoCode;
        document.getElementById('edit-promo-id').value = pc._id;
        document.getElementById('edit-description').value = pc.description;
        document.getElementById('edit-duration').value = pc.durationDays;
        document.getElementById('edit-max-redemptions').value = pc.maxRedemptions;
        document.getElementById('edit-valid-from').value = new Date(pc.validFrom).toISOString().split('T')[0];
        document.getElementById('edit-valid-until').value = new Date(pc.validUntil).toISOString().split('T')[0];
        openModal('promo-edit-modal');
      })
      .catch(function() { showToast('Failed to load promo code', 'error'); });
  }

  function savePromoCode() {
    var id = document.getElementById('edit-promo-id').value;
    var description = document.getElementById('edit-description').value.trim();
    var durationDays = document.getElementById('edit-duration').value;
    var maxRedemptions = document.getElementById('edit-max-redemptions').value;
    var validFrom = document.getElementById('edit-valid-from').value;
    var validUntil = document.getElementById('edit-valid-until').value;

    adminFetch('/admin/api/promo-codes/' + id, {
      method: 'PUT',
      body: JSON.stringify({ description, durationDays, maxRedemptions, validFrom, validUntil })
    })
    .then(function() {
      closeModal('promo-edit-modal');
      toastAndReload('Promo code updated');
    })
    .catch(function(e) { showToast(e.message || 'Failed to update', 'error'); });
  }

  function togglePromoCode(id, currentlyActive) {
    adminFetch('/admin/api/promo-codes/' + id, {
      method: 'PUT',
      body: JSON.stringify({ isActive: !currentlyActive })
    })
    .then(function() { toastAndReload(currentlyActive ? 'Code deactivated' : 'Code activated'); })
    .catch(function() { showToast('Failed to toggle status', 'error'); });
  }

  function deletePromoCode(id, code) {
    if (!confirm('Delete promo code "' + code + '"? This will also delete all redemption records.')) return;

    adminFetch('/admin/api/promo-codes/' + id, { method: 'DELETE' })
      .then(function() { toastAndReload('Promo code deleted'); })
      .catch(function() { showToast('Failed to delete promo code', 'error'); });
  }
</script>
